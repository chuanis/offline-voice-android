<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutNumpad"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F2F3F5"
    android:paddingTop="8dp"
    android:paddingBottom="25dp"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="0.8"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingEnd="2dp">

            <Button android:id="@+id/keyPlusNum" android:text="+" style="@style/NumKeyStyle" android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginBottom="8dp" android:textSize="20sp" android:textStyle="normal"/>
            <Button android:id="@+id/keyMinusNum" android:text="-" style="@style/NumKeyStyle" android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginBottom="8dp" android:textSize="20sp" android:textStyle="normal"/>
            <Button android:id="@+id/keyMultNum" android:text="*" style="@style/NumKeyStyle" android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginBottom="8dp" android:textSize="20sp" android:textStyle="normal"/>
            <Button android:id="@+id/keyDivNum" android:text="/" style="@style/NumKeyStyle" android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginBottom="8dp" android:textSize="20sp" android:textStyle="normal"/>
            <Button android:id="@+id/keyEqualNum" android:text="=" style="@style/NumKeyStyle" android:layout_width="match_parent" android:layout_height="42dp" android:layout_marginBottom="8dp" android:textSize="20sp" android:textStyle="normal"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="4.4"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="2dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/keyNum1" android:text="1" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum2" android:text="2" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum3" android:text="3" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <LinearLayout
                    android:id="@+id/btnDeleteNum"
                    android:layout_width="0dp"
                    android:layout_weight="0.8"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_white"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:src="@drawable/ic_backspace" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/keyNum4" android:text="4" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum5" android:text="5" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum6" android:text="6" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <LinearLayout
                    android:id="@+id/btnEnterNum"
                    android:layout_width="0dp"
                    android:layout_weight="0.8"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_white"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:src="@drawable/ic_enter" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/keyNum7" android:text="7" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum8" android:text="8" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum9" android:text="9" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyCommaNum" android:text="," style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="0.8" android:textSize="20sp" android:textStyle="normal"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/key00Num" android:text="00" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyNum0" android:text="0" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyPercentNum" android:text="%" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>
                <Button android:id="@+id/keyDotNum" android:text="." style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="0.8" android:textSize="20sp" android:textStyle="normal"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btnBackToSymFromNum"
                    android:text="!#@"
                    style="@style/NumKeyStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1.2"
                    android:textSize="16sp"
                    android:textColor="#000000"/>

                <Button android:id="@+id/btnSpaceNum" android:text="␣" style="@style/NumKeyStyle" android:layout_width="0dp" android:layout_weight="1.2" android:textSize="16sp" android:textStyle="normal"/>

                <LinearLayout
                    android:id="@+id/btnBackToQwertyFromNum"
                    android:layout_width="0dp"
                    android:layout_weight="1.2"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_white"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:text="ABC" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMicFromNum"
                    android:layout_width="0dp"
                    android:layout_weight="0.8"
                    android:layout_height="match_parent"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_key_white"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:src="@drawable/ic_mic" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="10dp"/>
</LinearLayout>