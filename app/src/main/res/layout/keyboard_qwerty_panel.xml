<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutQwerty"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F2F3F5"
    android:paddingTop="8dp"
    android:paddingBottom="25dp"
    android:visibility="gone">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <include layout="@layout/keyboard_super_symbol_panel" />
    </FrameLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:paddingHorizontal="2dp" android:layout_marginBottom="8dp">
        <Button android:id="@+id/keyQ" android:text="q" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyW" android:text="w" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyE" android:text="e" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyR" android:text="r" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyT" android:text="t" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyY" android:text="y" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyU" android:text="u" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyI" android:text="i" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyO" android:text="o" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyP" android:text="p" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:paddingHorizontal="2dp" android:layout_marginBottom="8dp">
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />
        <Button android:id="@+id/keyA" android:text="a" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyS" android:text="s" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyD" android:text="d" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyF" android:text="f" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyG" android:text="g" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyH" android:text="h" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyJ" android:text="j" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyK" android:text="k" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyL" android:text="l" style="@style/NumKeyStyle" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="0.5" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:paddingHorizontal="2dp" android:layout_marginBottom="8dp">
        <LinearLayout
            android:id="@+id/btnShift"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:src="@drawable/ic_shift_icon" android:layout_width="32dp" android:layout_height="32dp" android:padding="5dp" android:tint="#000000" android:clickable="false"/>
        </LinearLayout>

        <Button android:id="@+id/keyZ" android:text="z" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyX" android:text="x" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyC" android:text="c" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyV" android:text="v" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyB" android:text="b" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyN" android:text="n" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/keyM" android:text="m" style="@style/NumKeyStyle" android:layout_weight="1" android:textAllCaps="false" android:textSize="20sp" android:textStyle="normal"/>

        <LinearLayout
            android:id="@+id/btnDeleteQwerty"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:src="@drawable/ic_backspace" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="42dp" android:orientation="horizontal" android:paddingHorizontal="2dp" android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/btnBackToVoice"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:src="@drawable/ic_mic" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSwitchToSymbols"
            android:text="!#@"
            style="@style/NumKeyStyle"
            android:layout_weight="1.2"
            android:textSize="16sp"
            android:textColor="#000000"/>

        <Button android:id="@+id/btnComma" android:text="," style="@style/NumKeyStyle" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>

        <Button android:id="@+id/btnSpaceQwerty" android:text="␣" style="@style/NumKeyStyle" android:layout_weight="3.0" android:textSize="16sp" android:textStyle="normal"/>

        <Button android:id="@+id/btnSlashQwerty" android:text="/" style="@style/NumKeyStyle" android:layout_weight="1.2" android:textSize="20sp" android:textStyle="normal"/>

        <Button
            android:id="@+id/btnSwitchToNumpadQwerty"
            android:text="123"
            style="@style/NumKeyStyle"
            android:layout_weight="1.2"
            android:textSize="16sp"
            android:textColor="#000000"/>

        <LinearLayout
            android:id="@+id/btnEnterQwerty"
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:src="@drawable/ic_enter" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="10dp"/>
</LinearLayout>