<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️"
            android:textSize="18sp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CRITICAL: ENGLISH ONLY"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CORE ARCHITECTURE"
        android:textColor="#888888"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aegis AI uses a strictly English-native neural network for secure offline processing."
        android:textColor="#DDDDDD"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TARGET OPERATIONS"
        android:textColor="#888888"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Designed to convert English audio sources (Device Playback, Confidential Meetings, Interviews) directly into Markdown."
        android:textColor="#DDDDDD"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="INPUT HAZARD"
        android:textColor="#FF4444"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Non-English input will trigger Neural Hallucinations (random languages or incoherent text)."
        android:textColor="#FFCCCC"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_dialog_confirm"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="CONFIRM: SOURCE IS ENGLISH"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF4444"
        android:stateListAnimator="@null"
        android:layout_marginBottom="0dp"/>

</LinearLayout>