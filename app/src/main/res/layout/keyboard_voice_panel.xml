<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutVoiceMain"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F2F3F5"
    android:paddingTop="5dp"
    android:paddingBottom="25dp"
    android:visibility="visible">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/layoutTopStatusBar"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvListening"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Listening..."
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF4444"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Aegis AI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#AAAAAA"
                android:visibility="visible"/>

            <TextView
                android:id="@+id/tvCenterInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Queue: 0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FF8C00"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="5s"
                android:textSize="12sp"
                android:textColor="#6200EE"
                android:visibility="gone"/>
        </RelativeLayout>

        <include layout="@layout/keyboard_super_symbol_panel" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvGhostPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="#888888"
        android:paddingBottom="5dp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/rowNumbers"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btnNum1" android:text="1" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum2" android:text="2" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum3" android:text="3" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum4" android:text="4" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum5" android:text="5" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum6" android:text="6" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum7" android:text="7" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum8" android:text="8" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum9" android:text="9" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnNum0" android:text="0" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:paddingHorizontal="2dp"
        android:layout_marginBottom="8dp">
        <Button android:id="@+id/btnSymComma" android:text="," style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnSymPeriod" android:text="." style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnSymQuestion" android:text="?" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnSymExclamation" android:text="!" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnSymApostrophe" android:text="'" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnSymQuote" android:text="&quot;" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>
        <Button android:id="@+id/btnSymDash" android:text="-" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>

        <Button android:id="@+id/btnSymSlash" android:text="/" style="@style/NumKeyStyle" android:textSize="20sp" android:textStyle="normal"/>

        <Button android:id="@+id/btnSymSpace" android:text="␣" style="@style/NumKeyStyle" android:textSize="16sp" android:textStyle="normal" android:layout_weight="2"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/btnScenario"
            android:layout_width="0dp"
            android:layout_weight="0.8"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/tvScenarioText"
                android:text="GEN"
                android:textSize="16sp"
                android:textStyle="normal"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnSwitchToQwerty"
            android:layout_width="0dp"
            android:layout_weight="0.8"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView android:text="ABC" android:textSize="16sp" android:textStyle="normal" android:textColor="#000000" android:layout_width="wrap_content" android:layout_height="wrap_content" android:clickable="false"/>
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/btnMic"
            android:layout_width="0dp"
            android:layout_weight="2.4"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/imgPulseWave"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="6dp"
                android:src="@drawable/bg_pulse_ring"
                android:visibility="invisible"/>

            <ImageView
                android:id="@+id/imgMicIcon"
                android:src="@drawable/ic_mic"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="9dp"
                android:tint="#6200EE"
                android:clickable="false"/>

            <TextView
                android:id="@+id/tvMicHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="2dp"
                android:text="Hold / Tap"
                android:textSize="8sp"
                android:textColor="#888888"
                android:clickable="false"/>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_weight="0.8"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:src="@drawable/ic_backspace" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnEnter"
            android:layout_width="0dp"
            android:layout_weight="0.8"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:background="@drawable/bg_key_white"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:src="@drawable/ic_enter" android:layout_width="24dp" android:layout_height="24dp" android:tint="#000000" android:clickable="false"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>